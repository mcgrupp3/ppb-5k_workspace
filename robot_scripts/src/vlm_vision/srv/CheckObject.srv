# Label to look for (e.g. "a stop sign", "an apple", "person")
string object_name
---
bool success
# When success is true, present is the yes/no answer (true = yes)
bool present
# Literal "yes" or "no" for simple MCU / serial bridges
string yes_no
# Full model output (for logging)
string raw_answer
# Error or parse warning when success is false
string message
